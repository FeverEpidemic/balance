APP_DOMAIN=finance.example.com
APP_SITE_URL=https://finance.example.com
NEXT_PUBLIC_SITE_URL=https://finance.example.com

NEXT_PUBLIC_APP_NAME=balance

# Hosted Supabase:
# Project URL: Dashboard -> Connect
# Publishable/anon key: Dashboard -> Connect or Settings -> API Keys
NEXT_PUBLIC_SUPABASE_URL=https://finance.example.com/api
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Self-hosted Supabase / local reverse proxy:
SUPABASE_PUBLIC_URL=https://finance.example.com/api
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_JWT_SECRET=replace-with-long-random-secret

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=no-reply@example.com
