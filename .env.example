NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key
SCHEDULER_SUPABASE_URL=http://127.0.0.1:8000

NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_SITE_URL=http://localhost:3000
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true
REDIS_KEY_PREFIX=balance
REDIS_METRICS_ENABLED=false
REDIS_METRICS_INTERVAL_MS=60000
CHAT_API_RATE_LIMIT_ENABLED=true
CHAT_API_RATE_LIMIT_MAX_REQUESTS=60
CHAT_API_RATE_LIMIT_WINDOW_SECONDS=60
FREE_TIER_MAX_MONTHLY_TRANSACTIONS=20
TRANSACTION_RATE_LIMIT_ENABLED=true
TRANSACTION_RATE_LIMIT_MAX_REQUESTS=30
TRANSACTION_RATE_LIMIT_WINDOW_SECONDS=60
AI_CHAT_RATE_LIMIT_ENABLED=true
AI_CHAT_RATE_LIMIT_MAX_REQUESTS=20
AI_CHAT_RATE_LIMIT_WINDOW_SECONDS=60
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_CHAT_MODEL=deepseek-v4-flash
AI_CHAT_ENABLED=true

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SUPABASE_JWT_SECRET=change-me-to-a-long-random-secret
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_PUBLIC_URL=http://localhost:8000

# Default lokal untuk uji email invitation via Mailpit.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@balance.local

# Optional overrides untuk provider tertentu.
EMAIL_DELIVERY_PROVIDER=smtp
MXROUTE_SMTP_API_URL=https://smtpapi.mxroute.com/
RECURRING_SCHEDULER_INTERVAL_MS=60000
RECURRING_SCHEDULER_BATCH_SIZE=50
